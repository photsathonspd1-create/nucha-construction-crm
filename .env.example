# ============================================
# NUCHA CRM — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# LINE Messaging API (recommended — get from https://developers.line.biz/console/)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_user_id_or_group_id_here

# LINE Notify (legacy — deprecated, use LINE Messaging API above)
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# Telegram Bot (alternative to LINE — get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email (SMTP) — optional, for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
NOTIFY_EMAIL=admin@nuchainnovation.com

# Auto-reply (set to 'true' to enable)
AUTO_REPLY_ENABLED=false

# PromptDee AI (for auto-reply and copilot)
# Get API key from https://www.promptdee.net/
PROMPTDEE_API_KEY=your_api_key_here
